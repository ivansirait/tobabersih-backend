generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [postgis(schema: "extensions"), uuid_ossp(map: "uuid-ossp", schema: "extensions")]
}

model User {
  id            BigInt         @id @default(autoincrement())
  username      String?        @unique
  email         String         @unique
  passwordHash  String         @map("password_hash")
  fullName      String         @map("full_name")
  phoneNumber   String?        @map("phone_number")
  role          Role           @default(WARGA)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @default(now()) @updatedAt @map("updated_at")
  isActive      Boolean        @default(true)
  fcm_token     String?
  notifications Notification[]
  posts         Post[]
  reports       Report[]
  assigned      Task[]         @relation("TaskAssigner")
  tasks         Task[]         @relation("TaskDriver")
  // FIX: One-to-One dengan Truck — satu operator hanya boleh memegang satu truk
  truck         Truck?
  // Pelanggan yang ditangani oleh driver ini
  pelanggan     Pelanggan[]

  @@map("users")
}

model Pelanggan {
  id         BigInt   @id @default(autoincrement())
  nama       String
  alamat     String
  jenisUsaha String
  // FIX: driverId wajib (non-optional) — pelanggan harus selalu punya driver
  // Jika ingin ganti driver, ganti driverId dulu baru driver lama bisa dihapus
  driverId   BigInt
  driver     User     @relation(fields: [driverId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("pelanggan")
}

model Location {
  id           BigInt   @id @default(autoincrement())
  name         String
  locationType String   @map("location_type")
  isActive     Boolean  @default(true) @map("is_active")
  code         String?  @unique
  latitude     Decimal  @db.Decimal(10, 8)
  longitude    Decimal  @db.Decimal(11, 8)
  address      String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @map("updated_at")
  radius       Int?

  @@map("locations")
}

model Report {
  id            BigInt       @id @default(autoincrement())
  userId        BigInt?      @map("user_id")
  latitude      Decimal      @db.Decimal(10, 8)
  longitude     Decimal      @db.Decimal(11, 8)
  photoUrl      String?      @map("photo_url")
  description   String?
  photoAfterUrl String?      @map("photo_after_url")
  status        ReportStatus @default(PENDING)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @default(now()) @map("updated_at")
  email         String?
  pelapor       String?
  user          User?        @relation(fields: [userId], references: [id])
  // One-to-One: satu laporan -> satu task (sudah benar via @unique di Task.reportId)
  task          Task?

  @@map("reports")
}

model Truck {
  id              BigInt            @id @default(autoincrement())
  plateNumber     String            @unique @map("plate_number")
  // FIX: @unique memastikan One-to-One — satu operator hanya bisa memegang satu truk
  operatorId      BigInt?           @unique @map("operator_id")
  currentLat      Decimal?          @map("current_lat") @db.Decimal(10, 8)
  currentLong     Decimal?          @map("current_long") @db.Decimal(11, 8)
  lastPing        DateTime?         @map("last_ping")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @default(now()) @map("updated_at")
  status          TruckStatus       @default(AVAILABLE)
  brand           String?
  truckType       String?           @map("truck_type")
  unitCode        String?           @map("unit_code")
  lastLocation    String?           @map("last_location")
  locationHistory LocationHistory[]
  tasks           Task[]
  // FIX: tambahkan field balik untuk RouteTemplate (diperlukan Prisma)
  routeTemplates  RouteTemplate[]
  operator        User?             @relation(fields: [operatorId], references: [id])

  @@map("trucks")
}

model RouteTemplate {
  id        BigInt          @id @default(autoincrement())
  name      String
  truckId   BigInt
  dayOfWeek String
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  truck     Truck           @relation(fields: [truckId], references: [id], onDelete: Cascade)
  waypoints RouteWaypoint[]

  // Satu truk hanya boleh punya satu template per hari
  @@unique([truckId, dayOfWeek])
  @@map("route_templates")
}

model RouteWaypoint {
  id        BigInt        @id @default(autoincrement())
  routeId   BigInt
  order     Int
  name      String
  latitude  Float
  longitude Float
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  route     RouteTemplate @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@map("route_waypoints")
}

model LocationHistory {
  id        BigInt   @id @default(autoincrement())
  truckId   BigInt   @map("truck_id")
  latitude  Decimal  @db.Decimal(10, 8)
  longitude Decimal  @db.Decimal(11, 8)
  createdAt DateTime @default(now()) @map("created_at")
  truck     Truck    @relation(fields: [truckId], references: [id])

  @@map("location_history")
}

model Post {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  content     String
  category    Category @default(BERITA)
  imageUrl    String?  @map("image_url")
  isPublished Boolean  @default(false) @map("is_published")
  isFeatured  Boolean  @default(false) @map("is_featured")
  authorId    BigInt   @map("author_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  // Relasi dipertahankan; pembatasan "hanya Admin" dihandle di layer aplikasi
  author      User     @relation(fields: [authorId], references: [id])

  @@map("posts")
}

model Notification {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  title     String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model Task {
  id          BigInt     @id @default(autoincrement())
  taskNumber  String     @unique @map("task_number")
  type        String
  status      TaskStatus @default(DITUGASKAN)
  driverId    BigInt?    @map("driver_id")
  truckId     BigInt?    @map("truck_id")
  assignerId  BigInt?    @map("assigner_id")
  reportId    BigInt?    @unique @map("report_id")
  location    String
  latitude    Decimal?   @db.Decimal(10, 8)
  longitude   Decimal?   @db.Decimal(11, 8)
  description String?
  scheduledAt DateTime?  @map("scheduled_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  pelapor     String?
  assigner    User?      @relation("TaskAssigner", fields: [assignerId], references: [id])
  driver      User?      @relation("TaskDriver", fields: [driverId], references: [id])
  report      Report?    @relation(fields: [reportId], references: [id])
  truck       Truck?     @relation(fields: [truckId], references: [id])
  // FIX: One-to-One — satu task hanya punya satu foto (via @unique pada taskId)
  photo       TaskPhoto?

  @@map("tasks")
}

model TaskPhoto {
  id       BigInt   @id @default(autoincrement())
  // FIX: @unique memastikan One-to-One — satu task hanya bisa punya satu foto
  taskId   BigInt   @unique @map("task_id")
  photoUrl String   @map("photo_url")
  type     String
  createdAt DateTime @default(now()) @map("created_at")
  task     Task     @relation(fields: [taskId], references: [id])

  @@map("task_photos")
}

model gallery_albums {
  id             Int              @id(map: "GalleryAlbum_pkey") @default(autoincrement())
  title          String
  description    String?
  cover_url      String?
  created_at     DateTime         @default(now())
  updated_at     DateTime
  gallery_photos gallery_photos[]
}

model gallery_photos {
  id             Int            @id(map: "GalleryPhoto_pkey") @default(autoincrement())
  album_id       Int
  image_url      String
  caption        String?
  created_at     DateTime       @default(now())
  gallery_albums gallery_albums @relation(fields: [album_id], references: [id], onDelete: Cascade, map: "GalleryPhoto_album_id_fkey")
}

model edukasi {
  id         Int       @id @default(autoincrement())
  judul      String
  deskripsi  String?
  media_url  String
  media_type MediaType
  created_at DateTime  @default(now())
  updated_at DateTime
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  WARGA
  OPERATOR
  ADMIN
  KABID
}

enum ReportStatus {
  PENDING
  DITINDAKLANJUTI
  SELESAI
  DITOLAK
}

enum TruckStatus {
  AVAILABLE
  BUSY
  MAINTENANCE
}

enum Category {
  BERITA
  PENGUMUMAN
  PROFIL_DLH
  EDUKASI
}

enum TaskStatus {
  DITUGASKAN
  DITERIMA
  DALAM_PERJALANAN
  TIBA
  BEKERJA
  SELESAI
}

enum MediaType {
  IMAGE
  VIDEO
}